# -- Core --
NODE_ENV=development
PORT=5001
DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_SECRET=replace-with-strong-secret

# Driver login OTP: logged to backend terminal in non-production (unless SUPPRESS_CONSOLE_OTP=1).
# Non-production API also returns devOtp in POST /auth/driver/request-code so the driver app toast shows the code.
# If server logs still hide OTP, check LOG_LEVEL — logger.warn is suppressed when LOG_LEVEL=error.
# LOG_VERIFICATION_CODES=1
# SUPPRESS_CONSOLE_OTP=1

# Driver login: max OTP request-code calls per email per rolling hour (default 3 in production, 100 in dev).
# VERIFICATION_CODE_MAX_REQUESTS_PER_HOUR=100

# Express rate limit: max requests per IP per minute under /api/auth/* (default 5 in production, 200 in dev).
# AUTH_RATE_LIMIT_MAX=200

# -- Firebase Admin (auth + storage) --
# Option A (recommended on cloud): entire service account JSON in one env var.
FIREBASE_SERVICE_ACCOUNT_JSON={}
# Option B (local/dev): path to service-account JSON file, relative to repo root.
# FIREBASE_SERVICE_ACCOUNT_PATH=apps/backend/firebase-service-account.json
# Option C: split service account fields.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -- Email (Resend) --
RESEND_API_KEY=re_xxxx
FROM_EMAIL=noreply@laundryheap.com

# -- SMS (Twilio) --
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# -- Contract Signing (Docuseal, self-hosted) --
# Base URL the backend uses to call the Docuseal API. Either the bare host
# (https://docuseal.example.com) or the full /api prefix is accepted.
DOCUSEAL_BASE_URL=https://docuseal.example.com
# Optional: public URL drivers use to sign documents. Defaults to DOCUSEAL_BASE_URL.
DOCUSEAL_PUBLIC_URL=https://docuseal.example.com
# API key (X-Auth-Token) generated in Docuseal admin.
DOCUSEAL_API_KEY=xxxx
# Webhook secret used to verify HMAC-SHA256 signatures on incoming events.
DOCUSEAL_WEBHOOK_SECRET=xxxx

# -- File Storage (Firebase Storage) --
# Bucket name only, e.g. your-project-id.firebasestorage.app
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# -- URLs --
API_BASE_URL=http://localhost:5001
DRIVER_WEB_URL=http://localhost:3000
ADMIN_WEB_URL=http://localhost:3001

# -- Frontend (Vite) --
VITE_API_URL=http://localhost:5001/api
VITE_DRIVER_APP_URL=http://localhost:3000
VITE_ADMIN_APP_URL=http://localhost:3001
VITE_FIREBASE_API_KEY=xxxx
VITE_FIREBASE_AUTH_DOMAIN=xxxx
VITE_FIREBASE_PROJECT_ID=xxxx
VITE_FIREBASE_APP_ID=xxxx
